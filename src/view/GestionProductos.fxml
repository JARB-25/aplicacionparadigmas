<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ProductoController"
            prefWidth="980.0"
            prefHeight="680.0"
            style="-fx-background-color: #f4f6f0;">
    <top>
        <VBox style="-fx-background-color: #2e6b2e;">
            <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 16 24 16 24;">
                <VBox spacing="2.0">
                    <Label text="Finca Tomatera - Gestion de Insumos Agricolas"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Label text="Control de fertilizantes, insecticidas y abonos"
                           style="-fx-font-size: 12px; -fx-text-fill: #c8e6c9;" />
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.37" style="-fx-background-color: transparent; -fx-padding: 16;">
            <VBox spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                <Label text="Datos del Producto"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2e6b2e;" />
                <Separator />

                <VBox spacing="4.0">
                    <Label text="Nombre del producto *" style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                    <TextField fx:id="txtNombre" promptText="Ej: Nitrato de amonio"
                               style="-fx-background-radius: 6; -fx-border-color: #c8e6c9; -fx-border-radius: 6; -fx-padding: 7 10;" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Tipo de producto *" style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                    <ComboBox fx:id="cmbTipo" promptText="Seleccione un tipo" maxWidth="1.7976931348623157E308"
                              style="-fx-background-radius: 6; -fx-border-color: #c8e6c9; -fx-border-radius: 6;" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Cantidad disponible (kg/L) *" style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                    <TextField fx:id="txtCantidad" promptText="Ej: 25.5"
                               style="-fx-background-radius: 6; -fx-border-color: #c8e6c9; -fx-border-radius: 6; -fx-padding: 7 10;" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Precio (COP) *" style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                    <TextField fx:id="txtPrecio" promptText="Ej: 35000"
                               style="-fx-background-radius: 6; -fx-border-color: #c8e6c9; -fx-border-radius: 6; -fx-padding: 7 10;" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Fecha de registro *" style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                    <DatePicker fx:id="dpFecha" maxWidth="1.7976931348623157E308"
                                style="-fx-background-radius: 6; -fx-border-color: #c8e6c9; -fx-border-radius: 6;" />
                </VBox>

                <Separator />

                <GridPane hgap="8.0" vgap="8.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50.0" />
                        <ColumnConstraints percentWidth="50.0" />
                    </columnConstraints>
                    <Button text="Guardar" onAction="#guardar" maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #2e6b2e; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <Button text="Actualizar" onAction="#actualizar" maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #558b2f; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                    <Button text="Eliminar" onAction="#eliminar" maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #c62828; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <Button text="Limpiar" onAction="#limpiar" maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #eceff1; -fx-text-fill: #37474f; -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                </GridPane>

                <TextField fx:id="txtId" visible="false" managed="false" />
            </VBox>

            <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                <Label text="Inventario de Productos"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2e6b2e;" />
                <Separator />

                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <TextField fx:id="txtBuscar" promptText="Buscar por nombre, tipo o ID..."
                               style="-fx-background-radius: 20; -fx-border-color: #c8e6c9; -fx-border-radius: 20; -fx-padding: 6 14;"
                               HBox.hgrow="ALWAYS" />
                    <Button text="Ver todos" onAction="#verTodos"
                            style="-fx-background-color: #c8e6c9; -fx-text-fill: #2e6b2e; -fx-background-radius: 20; -fx-padding: 6 14; -fx-font-weight: bold;" />
                </HBox>

                <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="55.0" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colNombre" text="Nombre" prefWidth="170.0" />
                        <TableColumn fx:id="colTipo" text="Tipo" prefWidth="110.0" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colCantidad" text="Cantidad" prefWidth="95.0" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colPrecio" text="Precio (COP)" prefWidth="120.0" style="-fx-alignment: CENTER-RIGHT;" />
                        <TableColumn fx:id="colFecha" text="Fecha" prefWidth="110.0" style="-fx-alignment: CENTER;" />
                    </columns>
                    <placeholder>
                        <Label text="No hay productos registrados."
                               style="-fx-text-fill: #aaa; -fx-font-style: italic;" />
                    </placeholder>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="20.0"
                      style="-fx-background-color: #f4f6f0; -fx-background-radius: 6; -fx-padding: 8 14;">
                    <Label fx:id="lblTotal" text="Total de productos: 0"
                           style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                    <Label fx:id="lblSeleccionado" text="Ningun registro seleccionado"
                           style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-font-style: italic;" />
                </HBox>
            </VBox>
        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #2e6b2e; -fx-padding: 8 24;">
            <Label text="2026 - Finca Tomatera - Sistema de Gestion de Insumos Agricolas"
                   style="-fx-text-fill: #c8e6c9; -fx-font-size: 11px;" />
        </HBox>
    </bottom>

    <padding>
        <Insets bottom="0.0" left="0.0" right="0.0" top="0.0" />
    </padding>
</BorderPane>
